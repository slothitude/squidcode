# ── SquidCode v0.1 Configuration ──

# ICAP server (receives traffic from Squid)
ICAP_HOST=0.0.0.0
ICAP_PORT=1344

# SSE server (pushes updates to browser)
SSE_HOST=0.0.0.0
SSE_PORT=8080

# LLM provider (OpenAI-compatible)
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3

# Rewriting behaviour
REWRITE_STYLE=clarity          # clarity | simplify | formal | eli5
BATCH_SIZE=5

# Semantic cache
CACHE_SIMILARITY_THRESHOLD=0.85
CACHE_TTL_HOURS=24
CACHE_PERSIST_DIR=./cache_db

# RAG
RAG_DATA_DIR=./data

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Logging
LOG_LEVEL=INFO
